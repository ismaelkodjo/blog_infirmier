# Secret key (générer avec: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=votre-cle-secrete-ici

# Mode debug (False en production)
DEBUG=True

# Hôtes autorisés (séparés par des virgules)
ALLOWED_HOSTS=localhost,127.0.0.1

# URL du site
SITE_URL=http://localhost:8000

# Base de données (SQLite par défaut, PostgreSQL en production)
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=db.sqlite3
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=blog_infirmier_db
# DB_USER=postgres
# DB_PASSWORD=motdepasse
# DB_HOST=localhost
# DB_PORT=5432

# Email (console en dev, SMTP en production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
DEFAULT_FROM_EMAIL=Blog Infirmier <noreply@bloginfirmier.com>

# Email de destination des messages de contact (OBLIGATOIRE en production)
CONTACT_EMAIL=votre@email.com
